# Local secrets and runtime state
.env
.env.*
!.env.example
*.local

# Scout runtime state — cursors and queue items may contain raw scraped data
# we don't want in history until reviewed. Track structure (READMEs) but ignore
# per-run output.
/scout/state/*.json
/scout/state/*.yaml
!/scout/state/README.md
/scout/queue/*.md
!/scout/queue/README.md
!/scout/queue/_template.md

# Command center runtime logs
/command-center/threads/*.jsonl
/command-center/threads/*.log
!/command-center/threads/README.md
/command-center/token-burn/*.csv
/command-center/token-burn/*.jsonl
!/command-center/token-burn/README.md

# Phase 8 web app — frontend build artefacts and local config.
/web/apps/web/node_modules/
/web/apps/web/.next/
/web/apps/web/out/
/web/apps/web/.env.local
/web/apps/web/.env.*.local
/web/apps/web/next-env.d.ts.bak
